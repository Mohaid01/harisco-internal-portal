PORT=5000
DATABASE_URL="file:./dev.db"
NODE_ENV=development

# JWT Secret - REQUIRED in production! Generate a strong random string.
JWT_SECRET=change_me_to_a_strong_random_secret

# SMTP (optional - leave blank to use Ethereal test emails in development)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@harisco.com
# SMTP_PASS=your-email-password
