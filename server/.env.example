PORT=5000
DATABASE_URL="file:./dev.db"
NODE_ENV=development

# JWT Secret - Generate a strong random string for production
JWT_SECRET=change_me_to_a_strong_random_secret

# Google OAuth Credentials
# Get these from: https://console.cloud.google.com -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Authorized Redirect URIs to add in Google Cloud Console:
# Dev:  http://localhost:5000/auth/google/callback
# Prod: http://<YOUR_SERVER_IP>:5000/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# Frontend URL (for redirect after OAuth)
# Dev: http://localhost:5173  |  Production: http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Session secret (change in production)
SESSION_SECRET=change_me_to_a_strong_random_secret

# SMTP (optional - leave blank to use Ethereal test emails in development)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@harisco.com
# SMTP_PASS=your-email-password
